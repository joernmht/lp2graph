{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joernmht/lp2graph/schema/canonical.schema.json",
  "title": "lp2graph canonical formulation schema",
  "description": "Canonical typed-graph representation of an LP, MIP, or MILP formulation.",
  "type": "object",
  "required": ["schema_version", "id", "name", "family", "indices", "variables", "constraints"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "The version of the canonical schema this file conforms to."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "description": "Stable, lowercase identifier of the formulation."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name."
    },
    "family": {
      "enum": ["lp", "mip", "milp"],
      "description": "Optimization family."
    },
    "description": {
      "type": "string",
      "description": "Free-form explanation of the formulation."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Free-form labels (e.g. 'big-m', 'soft', 'cyclic')."
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "reference": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      }
    },
    "indices": {
      "type": "array",
      "items": { "$ref": "#/$defs/index" },
      "description": "Index families (sets) used by the formulation."
    },
    "parameters": {
      "type": "array",
      "items": { "$ref": "#/$defs/parameter" },
      "default": []
    },
    "variables": {
      "type": "array",
      "items": { "$ref": "#/$defs/variable_template" },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": { "$ref": "#/$defs/constraint_template" }
    },
    "objective": {
      "$ref": "#/$defs/objective"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "index": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "description": { "type": "string" },
        "ordered": {
          "type": "boolean",
          "default": false,
          "description": "Whether the index family has a natural order (enables offsets like t-1)."
        },
        "cyclic": {
          "type": "boolean",
          "default": false,
          "description": "Whether offsets wrap modulo cardinality (PESP-style)."
        }
      }
    },
    "parameter": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "description": { "type": "string" },
        "shape": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "default": [],
          "description": "Index families this parameter is shaped over (empty = scalar)."
        },
        "kind": {
          "enum": ["scalar", "vector", "matrix", "big_m", "tolerance"],
          "default": "scalar"
        },
        "domain_class": {
          "enum": ["cost_weight", "time_duration", "capacity", "demand", "network_structure", "penalty_bigM", "count_limit", "unclassified"],
          "description": "Optional domain-facet tag (additive). Independent of the structural 'kind'."
        }
      }
    },
    "variable_template": {
      "type": "object",
      "required": ["name", "domain"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "description": { "type": "string" },
        "shape": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "default": []
        },
        "domain": {
          "enum": ["continuous", "non_negative", "integer", "binary"],
          "description": "Variable domain. 'binary' implies {0,1}; 'integer' is unconstrained-sign integers."
        },
        "lower": { "type": ["number", "null"] },
        "upper": { "type": ["number", "null"] },
        "role": {
          "enum": ["primary", "auxiliary", "slack", "indicator"],
          "default": "primary"
        },
        "domain_role": {
          "enum": ["selection_assignment", "ordering_precedence", "routing_path_column", "timing", "flow_quantity", "auxiliary_linearization", "unclassified"],
          "description": "Optional domain-facet tag (additive). Independent of the structural 'role'/'domain'."
        }
      }
    },
    "quantifier": {
      "type": "object",
      "required": ["index", "over"],
      "additionalProperties": false,
      "properties": {
        "index": { "$ref": "#/$defs/identifier" },
        "over": { "$ref": "#/$defs/identifier", "description": "Index family being quantified over." },
        "restriction": {
          "enum": ["none", "ne_other", "lt_other", "le_other", "gt_other", "ge_other", "ordered_pair"],
          "default": "none",
          "description": "Inter-quantifier restriction (e.g. i != j)."
        },
        "restriction_other": {
          "type": ["string", "null"],
          "default": null,
          "description": "Name of the other quantifier the restriction refers to."
        },
        "where": {
          "type": ["object", "null"],
          "default": null,
          "additionalProperties": false,
          "required": ["parameter", "equals"],
          "properties": {
            "parameter": {
              "$ref": "#/$defs/identifier",
              "description": "Parameter shaped over the quantifier's index family used as a selection predicate."
            },
            "equals": {
              "type": ["boolean", "number", "string"],
              "description": "Value the parameter must equal for the tuple to be admitted."
            }
          },
          "description": "Attribute-based selection: keep only index values where the named parameter equals the given value."
        }
      }
    },
    "binding": {
      "type": "object",
      "required": ["index", "expr"],
      "additionalProperties": false,
      "properties": {
        "index": {
          "$ref": "#/$defs/identifier",
          "description": "Position name on the referenced template (matches one of its shape entries)."
        },
        "expr": {
          "type": "string",
          "description": "Symbolic expression in the constraint's quantifier scope, e.g. 't', 't-1', 't+k mod T'."
        },
        "offset": {
          "type": "integer",
          "default": 0,
          "description": "Numeric offset extracted from expr; ground view applies this."
        },
        "modulo": {
          "type": ["string", "null"],
          "default": null,
          "description": "Index family name to wrap modulo (PESP); null means no wrap."
        }
      }
    },
    "term": {
      "type": "object",
      "required": ["role"],
      "additionalProperties": false,
      "properties": {
        "ref": {
          "$ref": "#/$defs/identifier",
          "description": "Name of a variable_template or parameter. May be omitted for constant terms (use 'constant' instead). The legacy spelling 'one' with ref_kind='literal' is still accepted."
        },
        "ref_kind": {
          "enum": ["variable", "parameter", "literal"],
          "default": "variable"
        },
        "constant": {
          "type": "number",
          "description": "Numeric constant value for the term. When set, the term is treated as a literal whose value is this number; 'ref' and 'coefficient' must be omitted."
        },
        "bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/binding" },
          "default": []
        },
        "coefficient": {
          "type": ["string", "number", "null"],
          "default": 1,
          "description": "Scalar literal or parameter name; multiplied with sign."
        },
        "sign": {
          "enum": [1, -1],
          "default": 1
        },
        "role": {
          "enum": ["lhs", "rhs", "objective", "slack", "aux"],
          "description": "Role of this term in the constraint or objective."
        },
        "operator": {
          "enum": ["none", "sum", "max", "min", "abs", "indicator", "modulo"],
          "default": "none",
          "description": "Aggregation operator applied to the term, if any."
        },
        "operator_over": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "default": [],
          "description": "Index families the operator aggregates over (e.g. sum_{t in T})."
        }
      }
    },
    "constraint_template": {
      "type": "object",
      "required": ["name", "comparator", "lhs", "rhs"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "description": { "type": "string" },
        "quantifiers": {
          "type": "array",
          "items": { "$ref": "#/$defs/quantifier" },
          "default": []
        },
        "comparator": {
          "enum": ["le", "ge", "eq"]
        },
        "lhs": {
          "type": "array",
          "items": { "$ref": "#/$defs/term" }
        },
        "rhs": {
          "type": "array",
          "items": { "$ref": "#/$defs/term" }
        },
        "kind": {
          "enum": [
            "linear",
            "big_m",
            "indicator",
            "ordering",
            "headway",
            "capacity",
            "flow_balance",
            "modulo",
            "soft",
            "robust",
            "set_packing",
            "block_occupation",
            "moving_block",
            "dwell"
          ],
          "default": "linear"
        },
        "domain_class": {
          "enum": ["assignment_covering", "flow_conservation", "capacity_resource", "precedence_ordering", "headway_separation", "timing_window", "coupling_linking_definition", "periodic_modulo_pesp", "subtour_connectivity", "variable_bound_fix", "objective_defining", "unclassified"],
          "description": "Optional domain-facet tag (additive). Independent of the structural 'kind'."
        }
      }
    },
    "objective": {
      "type": "object",
      "required": ["sense", "terms"],
      "additionalProperties": false,
      "properties": {
        "sense": {
          "enum": ["min", "max"]
        },
        "name": {
          "type": "string",
          "default": "objective"
        },
        "description": { "type": "string" },
        "terms": {
          "type": "array",
          "items": { "$ref": "#/$defs/term" }
        },
        "combination": {
          "enum": ["sum", "lexicographic", "weighted_sum"],
          "default": "sum",
          "description": "How multiple terms are combined when the objective is decomposed."
        }
      }
    }
  }
}
